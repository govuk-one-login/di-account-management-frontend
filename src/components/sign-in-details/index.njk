{% extends "common/layout/base-page.njk" %}
{% set pageTitleName = 'pages.signInDetails.title' | translate %}
{% set rowContainerId = 'your-account' %}
{% set h2Class = 'govuk-heading-l' %}
{% set backLink = "SECURITY" | getPath %}
{% set backLinkText = 'pages.signInDetails.backLinkText' | translate  %}

{% block pageContent %}
  <h1 class="govuk-heading-xl landing-page__heading">{{ 'pages.signInDetails.header' | translate }}</h1>
  <p class="govuk-body landing-page__summary">{{ 'pages.signInDetails.paragraph' | translate }}</p>

  <div class="summary-list-container">
    <h2 class={{h2Class}}>{{ 'pages.signInDetails.email.heading' | translate }}</h2>
    <p class="govuk-body">{{ email }}</p>
    <p class="govuk-body">
      <a class="govuk-link" href={{ enterPasswordUrls.changeEmail }}>{{ "pages.signInDetails.email.changeLink" | translate }}</a>
    </p>
  </div>

  {% if passkeys.length %}
  <div class="summary-list-container">
    <div class="summary-list-container__content">
      <h2 class={{h2Class}}>{{ 'pages.signInDetails.passkeys.heading' | translate }}</h2>
      <p class="govuk-body">{{ 'pages.signInDetails.passkeys.paragraph1' | translate }}</p>
    </div>

    <div class="summary-list-container__content">
      <h3 class="govuk-heading-m">{% if passkeys.length > 1 %}{{ 'pages.signInDetails.passkeys.subheadingMany' | translate }}{% else %}{{ 'pages.signInDetails.passkeys.subheadingOne' | translate }}{% endif %}</h3>

      <ul class="govuk-list">
        {%- for passkey in passkeys -%}
        <li class="summary-list-container__content" data-test-id="passkey">
          <p class="govuk-body govuk-!-margin-bottom-0">{{ 'pages.signInDetails.passkeys.savedTo' | translate }}
            {%- if passkey.name -%}
              {{passkey.name}}
            {%- else -%}
              {{- 'pages.signInDetails.passkeys.unknownProvider' | translate -}}
            {%- endif -%}
          </p>
          <p class="govuk-body govuk-!-margin-bottom-0">
            {{ 'pages.signInDetails.passkeys.setUp' | translate }} {{ passkey.createdAt }}
          </p>
          {% if passkey.lastUsedAt %}
            <p class="govuk-body govuk-!-margin-bottom-0">
              {{- 'pages.signInDetails.passkeys.lastUsed' | translate -}} {{ passkey.lastUsedAt }}
            </p>
          {% endif %}
          <p class="govuk-body">
            <a href="{{[enterPasswordUrls.removePasskey, "&passkeyId=", passkey.id] | join }}" class="govuk-link">
            {{- 'pages.signInDetails.passkeys.removeWithHiddenText' | translate | safe | replace("[passkeyName]", passkey.name) if passkey.name -}}
            {{- 'pages.signInDetails.passkeys.remove' | translate if not passkey.name -}}
            </a>
          </p>
        </li>
        {%- endfor -%}
      </ul>
    </div>
    {% if passkeys.length < maxNumberOfPasskeys %}
      <div class="summary-list-container__content govuk-!-display-none" hidden id="create-passkey-box" data-test-id="create-passkey-box">
        <h3 class="govuk-heading-m">{{ 'pages.signInDetails.passkeys.setUpAnotherPasskey' | translate }}</h3>
        <p class="govuk-body"><a class="govuk-link" href="{{ enterPasswordUrls.createPasskey}}">{{ 'pages.signInDetails.passkeys.setUpAnotherPasskeyLinkText' | translate }}</a></p>
      </div>
    {% endif %}
  </div>
  {% endif %}

  <div class="summary-list-container">
    <h2 class={{h2Class}}>{{ 'pages.signInDetails.password.heading' | translate }}</h2>
    <p class="govuk-body">••••••••••••••••</p>
    <p class="govuk-body">
      <a class="govuk-link" href={{ enterPasswordUrls.changePassword }}>{{ "pages.signInDetails.password.changeLink" | translate }}</a>
    </p>
  </div>

  {# UCD want the passkey box to sit under the password box if no passkeys have been set up. #}
  {% if not passkeys.length %}
  <div class="summary-list-container govuk-!-display-none" hidden id="create-passkey-box" data-test-id="create-passkey-box">
    <h2 class={{h2Class}}>{{ 'pages.signInDetails.noPasskey.heading' | translate }}</h2>
    <p class="govuk-body">{{ 'pages.signInDetails.noPasskey.paragraph' | translate }}</p>
    <p class="govuk-body">
      <a class="govuk-link" href={{ enterPasswordUrls.createPasskey }}>{{ "pages.signInDetails.noPasskey.linkText" | translate }}</a>
    </p>
  </div>
  {% endif %}

  <div class="summary-list-container">
    <div class="summary-list-container__content">
      <h2 class={{h2Class}}>{{ 'pages.signInDetails.mfaSection.heading' | translate }}</h2>
    </div>
    {% if mfaMethods | length > 0 %}
      {% set foundPrimary = false %}
      {% set foundSecondary = false %}
      {% for method in mfaMethods %}
        {% if (method.priorityIdentifier == "DEFAULT") and not foundPrimary %}
          {# display existing primary method with options to change the method or use a different type #}
          <div class="summary-list-container__content" data-test-id="mfa-summary-list">
            <h3 class="govuk-heading-m">{{'pages.signInDetails.mfaSection.defaultMethod.heading' | translate }}</h3>
            <p class="govuk-body">{{ method.text }}</p>
            <p class="govuk-body"><a href="{{ method.linkHref }}" class="govuk-link"> {{ method.linkText }}</a></p>
            {% if canChangeTypeofPrimary %}
            <p class="govuk-body"><a href="{{enterPasswordUrls.changeDefaultMethod}}" class="govuk-link"> {{ ['pages.signInDetails.mfaSection.defaultMethod.change'] | join | translate }}</a></p>
            {% endif %}
          </div>
          {% set foundPrimary = true %}
        {% endif %}
      {% endfor %}

      {# backup mfa block has two states #}
      <div class="summary-list-container__content">
        {% for method in mfaMethods %}
          {% if (method.priorityIdentifier == "BACKUP") and not foundSecondary %}
            {# 1: backup method exists => display backup method block with options to change backup method or switch primary and backup #}
            <h3 class='govuk-heading-m'>{{ 'pages.signInDetails.mfaSection.backup.heading' | translate }}</h3>
            <p class="govuk-body">{{ method.text }}</p>
            <p class="govuk-body"><a href="{{enterPasswordUrls.switchBackupMethod}}" class="govuk-link"> {{ 'pages.signInDetails.mfaSection.backup.switchLink' | translate }}</a></p>
            <p class="govuk-body"><a href="{{enterPasswordUrls.removeBackupMethod}}" class="govuk-link"> {{ 'pages.signInDetails.mfaSection.backup.removeLink' | translate }}</a></p>
            {% set foundSecondary = true %}
          {% endif %}
        {% endfor %}
        {% if not foundSecondary %}
          <h3 class='govuk-heading-m'>{{ 'pages.signInDetails.mfaSection.backup.headingNoBackup' | translate }}</h3>
          {# 2: backup method does not exist => display option to add a new backup method #}
          <p class="govuk-body">{{ 'pages.signInDetails.mfaSection.backup.paragraph' | translate }}</p>
          <p class="govuk-body">{{ 'pages.signInDetails.mfaSection.backup.paragraph2' | translate }}</p>
          <p class="govuk-body">
            <a href="{{enterPasswordUrls.addBackupMethod}}" class="govuk-link">{{ 'pages.signInDetails.mfaSection.backup.link' | translate }}</a>
          </p>
        {% endif %}
      </div>
    {% endif %}
  </div>
{% endblock %}

{% block scripts %}
    <script type="module" src="/public/scripts/index.es5.umd.min.js?{{ staticHash }}" {% if scriptNonce %} nonce="{{ scriptNonce }}"{% endif %}></script>

    <script type="module" {% if scriptNonce %} nonce="{{ scriptNonce }}"{%  endif %}>
      if (SimpleWebAuthnBrowser.browserSupportsWebAuthn()) {
        const passkeyBox = document.getElementById("create-passkey-box");
        if (passkeyBox) {
          passkeyBox.classList.remove("govuk-!-display-none");
          passkeyBox.removeAttribute("hidden");
        }
      }
    </script>
{% endblock %}
