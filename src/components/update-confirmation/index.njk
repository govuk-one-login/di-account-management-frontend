{% extends "common/layout/base-page.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/panel/macro.njk" import govukPanel %}
{% set pageTitleName = pageTitle %}
{% set hideAccountNavigation = hideAccountNavigation %}
{% set govUkLink = "https://www.gov.uk" %}
{% set taxonomyLevel2 = taxonomyLevel2 %}

{% block pageContent %}

{{ govukPanel({
  titleText: panelText
}) }}

{% if summaryText %}
  <p class="govuk-body">{{summaryText | safe }}</p>
{% endif %}

{{ summaryHtml | safe }}


{% if showGovUKButton %}
{{ govukButton({
  text: 'general.backToGovUKButtonText' | translate,
  href: govUkLink,
  attributes: {
    "data-nav": true,
    "data-link": govUkLink
  }
}) }}
{% else %}
{{ govukButton({
  text: 'general.backToSignInDetailsButtonText' | translate if passkeysEnabled else 'general.backToSecurityButtonText' | translate,
  href: cancelAMJourneyHref,
  attributes: {
    "data-nav": true,
    "data-link": cancelAMJourneyHref
  }
}) }}
{% endif %}
{% endblock %}