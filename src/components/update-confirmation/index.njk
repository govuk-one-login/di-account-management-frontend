{% extends "common/layout/base-page.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/panel/macro.njk" import govukPanel %}
{% set pageTitleName = pageTitle %}
{% set hideAccountNavigation = hideAccountNavigation %}
{% set taxonomyLevel2 = taxonomyLevel2 %}

{% block pageContent %}

{{ govukPanel({
  titleText: panelText
}) }}

{% if summaryText %}
  <p class="govuk-body">{{summaryText | safe }}</p>
{% endif %}

{{ summaryHtml | safe }}

{{ govukButton({
  text: backButton.text,
  href: backButton.url,
  attributes: {
    "data-nav": true,
    "data-link": backButton.url
  }
}) }}
{% endblock %}
