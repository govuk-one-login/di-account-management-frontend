{
  "name": "end-to-end-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for the account management frontend.",
  "scripts": {
    "build-and-run-app": "cd ../ && docker compose build && docker compose up",
    "build": "docker build -t di-account-management-frontend-end-to-end-test .",
    "install-browsers": "playwright install --with-deps chromium",
    "start-test-server": "npm run build && docker run --network=host --rm --init di-account-management-frontend-end-to-end-test run-server",
    "watch": "nodemon -w ./tests -w ./utils -w ./.env.ts -w ./.env -e \"*\" --exec \"bddgen\"",
    "test": "npm ci && bddgen && playwright test",
    "test:update-snapshots": "npm ci && bddgen && playwright test --update-snapshots",
    "test:ui": "npm ci && run-p test:ui:*",
    "test:ui:watch": "npm run watch",
    "test:ui:run": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/govuk-one-login/di-account-management-frontend.git"
  },
  "bugs": {
    "url": "https://github.com/govuk-one-login/di-account-management-frontend/issues"
  },
  "homepage": "https://github.com/govuk-one-login/di-account-management-frontend#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/compat": "^1.3.1",
    "@eslint/js": "^9.30.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.26",
    "dotenv": "^16.5.0",
    "eslint": "^9.30.0",
    "msw": "^2.10.2",
    "nodemon": "^3.1.10",
    "npm-run-all": "^4.1.5",
    "playwright-bdd": "^8.2.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "valibot": "^1.1.0"
  }
}
