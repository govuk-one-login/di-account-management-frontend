{
  "$schema": "https://raw.githubusercontent.com/govuk-one-login/quality-gates/refs/tags/v0.1.0/schemas/schema.json",
  "services": [
    {
      "service-tag": "home",
      "quality-gates": [
        {
          "check-types": [
            "code quality",
            "code style and linting",
            "secret scanning"
          ],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/lint.yaml",
            "path": "jobs.lint",
            "name": "Lint"
          }
        },
        {
          "check-types": ["vulnerability detection"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/dependency-review.yaml",
            "path": "jobs.dependency-review",
            "name": "Dependency Review"
          }
        },
        {
          "check-types": [
            "code quality",
            "unit test coverage",
            "vulnerability detection"
          ],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/sonarcloud.yaml",
            "path": "jobs.sonarcloud",
            "name": "Run Sonar scan"
          }
        },
        {
          "check-types": ["integration", "new feature", "regression", "unit"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/local-tests-unit.yaml",
            "path": "jobs.local-tests-unit",
            "name": "Local tests (unit)"
          }
        },
        {
          "check-types": ["accessibility", "integration", "regression"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/local-tests-integration.yaml",
            "path": "jobs.local-tests-integration",
            "name": "playwright-test-results"
          }
        },
        {
          "check-types": ["integration", "new feature", "regression", "unit"],
          "provider": "GitHub",
          "phase": "pre-upload",
          "config": {
            "file": ".github/workflows/on-merge-to-main.yaml",
            "path": "jobs.validate_application",
            "name": "App Checks"
          }
        },
        {
          "check-types": ["accessibility", "integration", "regression"],
          "provider": "Stack Orchestrator",
          "phase": "build",
          "config": {
            "file": "integration-tests/Dockerfile"
          }
        }
      ]
    }
  ]
}
